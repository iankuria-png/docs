  "keyFeatures": [
    "Client profile management with WordPress sync",
    "Lead pipeline with scraper import and CSV upload",
    "Deal and subscription lifecycle management",
    "Automated and manual payment matching",
    "Renewal campaign automation with reminders",
    "Push notification campaign builder",
    "Multi-market revenue dashboard with FX normalization",
    "Team leaderboard and performance goals",
    "Role-based access control (admin, sub-admin, sales, marketing)",
    "Billing provider routing rules per market",
    "FAQ and internal knowledge base",
    "Audit log and timeline events per client"
  ],
  "publicApiSurface": [
    "POST /api/crm/login",
    "GET /api/crm/me",
    "GET /api/crm/dashboard",
